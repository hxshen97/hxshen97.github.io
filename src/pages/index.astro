---
// src/pages/index.astro
import SidebarLayout from '../layouts/SidebarLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PublicationCard from '../components/PublicationCard.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { t, type Lang } from '../i18n/ui';
const lang: Lang = 'en';

const featuredProjects = (await getCollection('projects', ({ data }) => data.featured))
  .slice(0, 3);
const publications = (await getCollection('publications'))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 2);
const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);
---
<SidebarLayout title="Home" description="Hanxiang Shen" lang={lang}>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-photo">
        <img src="/profile.jpg" alt="Hanxiang Shen" />
      </div>
      <div class="hero-text">
        <h1><span class="gradient-text">Hanxiang Shen</span></h1>
        <p class="role">{t(lang, 'home.role')}</p>
        <p class="bio">
          {t(lang, 'home.bio')}
        </p>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  {featuredProjects.length > 0 && (
    <section class="section">
      <div class="section-header">
        <h2>{t(lang, 'home.featuredProjects')}</h2>
        <a href="/projects/" class="see-all">{t(lang, 'home.allProjects')}</a>
      </div>
      <div class="card-grid">
        {featuredProjects.map(p => (
          <ProjectCard
            title={p.data.title}
            description={p.data.description}
            tags={p.data.tags}
            repo={p.data.repo}
            demo={p.data.demo}
            slug={p.slug}
            lang={lang}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Publications -->
  {publications.length > 0 && (
    <section class="section">
      <div class="section-header">
        <h2>{t(lang, 'home.publications')}</h2>
        <a href="/publications/" class="see-all">{t(lang, 'home.allPublications')}</a>
      </div>
      <div class="pub-grid">
        {publications.map(p => (
          <PublicationCard
            title={p.data.title}
            authors={p.data.authors}
            venue={p.data.venue}
            year={p.data.year}
            tags={p.data.tags}
            pdf={p.data.pdf}
            abstract={p.data.abstract}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Recent Posts -->
  {recentPosts.length > 0 && (
    <section class="section">
      <div class="section-header">
        <h2>{t(lang, 'home.recentPosts')}</h2>
        <a href="/blog/" class="see-all">{t(lang, 'home.allPosts')}</a>
      </div>
      <div class="card-grid">
        {recentPosts.map(p => (
          <PostCard
            title={p.data.title}
            date={p.data.date}
            description={p.data.description}
            tags={p.data.tags}
            slug={p.slug}
            lang={lang}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Contact Strip -->
  <section class="contact-strip">
    <p>{t(lang, 'home.getInTouch')}</p>
    <div class="contact-links">
      <a href="mailto:hxshen_fdu@outlook.com">Email</a>
      <a href="https://github.com/hxshen97" target="_blank" rel="noopener">GitHub</a>
    </div>
  </section>

</SidebarLayout>

<style>
/* ── Hero ─────────────────────────────────────── */
.hero {
  padding: 3rem 0 4rem;
}
.hero-content {
  display: flex;
  align-items: stretch;
  gap: 2.5rem;
}
.hero-text { flex: 1; }
.hero-photo {
  flex-shrink: 0;
  width: 220px;
}
.hero-photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 8px;
}
@media (max-width: 768px) {
  .hero { padding: 2rem 0 3rem; }
  .hero-content {
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }
  .hero-photo {
    width: 160px;
    height: 250px;
  }
}
.hero h1 {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 5vw, 3.5rem);
  font-weight: 600;
  letter-spacing: -0.28px;
  line-height: 1.07;
  margin-bottom: 0.75rem;
  color: #1d1d1f;
}
.role {
  font-family: var(--font-display);
  font-size: 1.31rem;
  font-weight: 400;
  line-height: 1.19;
  letter-spacing: 0.231px;
  color: rgba(0, 0, 0, 0.56);
  margin-bottom: 1rem;
}
.bio {
  font-size: 1.06rem;
  max-width: 520px;
  color: rgba(0, 0, 0, 0.56);
  line-height: 1.47;
  letter-spacing: -0.374px;
  margin-bottom: 2rem;
}
.cta { display: flex; gap: 0.75rem; flex-wrap: wrap; }

/* ── Buttons (Apple) ──────────────────────────── */
.btn {
  display: inline-block;
  font-family: var(--font-text);
  font-size: 17px;
  font-weight: 400;
  line-height: 1;
  transition: background 0.2s, opacity 0.2s;
}
.btn-primary {
  background: #0071e3;
  color: #ffffff;
  padding: 8px 16px;
  border-radius: 980px;
  border: none;
}
.btn-primary:hover { background: #0077ED; color: #ffffff; text-decoration: none; }
.btn-secondary {
  background: transparent;
  color: #0066cc;
  padding: 8px 16px;
  border-radius: 980px;
  border: 1px solid #0066cc;
}
.btn-secondary:hover { background: rgba(0, 102, 204, 0.06); color: #0066cc; text-decoration: none; }

/* ── Sections ─────────────────────────────────── */
.section {
  margin-bottom: 3.5rem;
  padding-top: 2rem;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 1.5rem;
}
.section-header h2 {
  font-family: var(--font-display);
  font-size: 1.75rem;
  font-weight: 600;
  line-height: 1.14;
  letter-spacing: -0.28px;
  color: #1d1d1f;
}
.see-all {
  font-size: 0.875rem;
  color: #0066cc;
  letter-spacing: -0.224px;
}
.see-all:hover { color: #0066cc; }

.card-grid {
  display: grid;
  gap: 1rem;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
}
.pub-grid {
  display: grid;
  gap: 1rem;
  grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
}

/* ── Divider between sections ─────────────────── */
.section + .section {
  border-top: 1px solid rgba(0, 0, 0, 0.06);
}

/* ── Contact Strip ────────────────────────────── */
.contact-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 1rem;
  padding-top: 2.5rem;
  margin-top: 2rem;
  border-top: 1px solid rgba(0, 0, 0, 0.06);
  color: rgba(0, 0, 0, 0.56);
  font-size: 0.875rem;
  letter-spacing: -0.224px;
}
.contact-links { display: flex; gap: 1.5rem; }
.contact-links a {
  color: #0066cc;
  font-size: 0.875rem;
  padding: 6px 14px;
  border: 1px solid rgba(0, 102, 204, 0.3);
  border-radius: 980px;
  transition: background 0.2s;
}
.contact-links a:hover {
  background: rgba(0, 102, 204, 0.06);
  text-decoration: none;
}
</style>
