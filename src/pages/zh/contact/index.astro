---
// src/pages/zh/contact/index.astro
import SidebarLayout from '../../../layouts/SidebarLayout.astro';
import { t, type Lang } from '../../../i18n/ui';
const lang: Lang = 'zh';
---
<SidebarLayout title={t(lang, 'contact.title')} description="联系我。" lang={lang}>
  <h1>{t(lang, 'contact.title')}</h1>
  <p class="subtitle">{t(lang, 'contact.subtitle')}</p>

  <div class="contact-list">
    <a href="mailto:hxshen97_fdu@outlook.com" class="contact-item">
      <span class="contact-label">邮件</span>
      <span class="contact-value">hxshen97_fdu@outlook.com</span>
    </a>
    <a href="https://github.com/hxshen97" target="_blank" rel="noopener" class="contact-item">
      <span class="contact-label">GitHub</span>
      <span class="contact-value">github.com/hxshen97</span>
    </a>
    <a href="https://linkedin.com/in/瀚翔-沈-991176310" target="_blank" rel="noopener" class="contact-item">
      <span class="contact-label">领英</span>
      <span class="contact-value">https://linkedin.com/in/瀚翔-沈-991176310</span>
    </a>
  </div>
</SidebarLayout>

<style>
h1 { font-size: 2rem; margin-bottom: 0.5rem; }
.subtitle { color: var(--text-muted); margin-bottom: 2.5rem; }

.contact-list { display: flex; flex-direction: column; gap: 1rem; max-width: 480px; }
.contact-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1rem 1.25rem;
  background: var(--bg-surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  transition: border-color 0.2s;
  color: var(--text);
}
.contact-item:hover { border-color: var(--accent-1); color: var(--text); }
.contact-label {
  font-size: 0.8rem;
  font-family: var(--font-sans);
  font-weight: 600;
  color: var(--accent-1);
}
.contact-value { font-size: 0.9rem; color: var(--text-muted); }
</style>
