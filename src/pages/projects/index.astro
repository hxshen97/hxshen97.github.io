---
// src/pages/projects/index.astro
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import TagFilter from '../../components/TagFilter.astro';
import { getCollection } from 'astro:content';
import { t, type Lang } from '../../i18n/ui';
const lang: Lang = 'en';

const projects = await getCollection('projects');
const allTags = [...new Set(projects.flatMap(p => p.data.tags))].sort();
---
<SidebarLayout title={t(lang, 'projects.title')} description={t(lang, 'projects.subtitle')} lang={lang}>
  <h1>{t(lang, 'projects.title')}</h1>
  <p class="subtitle">{t(lang, 'projects.subtitle')}</p>

  <TagFilter tags={allTags} lang={lang} />

  <div class="card-grid">
    {projects.map(p => (
      <ProjectCard
        title={p.data.title}
        description={p.data.description}
        tags={p.data.tags}
        repo={p.data.repo}
        demo={p.data.demo}
        slug={p.slug}
        lang={lang}
      />
    ))}
  </div>
</SidebarLayout>

<style>
h1 { font-size: 2rem; margin-bottom: 0.5rem; }
.subtitle { color: var(--text-muted); margin-bottom: 2rem; }
.card-grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }
</style>
