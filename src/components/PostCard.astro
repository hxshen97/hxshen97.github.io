---
// src/components/PostCard.astro
import TagChip from './TagChip.astro';
import { localizedPath, type Lang } from '../i18n/ui';

interface Props {
  title: string;
  date: Date;
  description: string;
  tags: string[];
  slug: string;
  lang?: Lang;
}
const { title, date, description, tags, slug, lang = 'en' } = Astro.props;
const locale = lang === 'zh' ? 'zh-CN' : 'en-US';
const formatted = date.toLocaleDateString(locale, {
  year: 'numeric', month: 'short', day: 'numeric',
});
---
<article class="card post-card" data-tags={tags.join(',')}>
  <time class="date" datetime={date.toISOString()}>{formatted}</time>
  <h3><a href={localizedPath(`/blog/${slug}`, lang)}>{title}</a></h3>
  <p class="desc">{description}</p>
  <div class="tags">
    {tags.map(t => <TagChip tag={t} />)}
  </div>
</article>

<style>
.post-card { display: flex; flex-direction: column; gap: 0.35rem; }
.date {
  font-size: 0.75rem;
  color: rgba(0, 0, 0, 0.48);
  font-family: var(--font-text);
  letter-spacing: -0.12px;
}
.post-card h3 {
  font-family: var(--font-display);
  font-size: 1.19rem;
  font-weight: 600;
  line-height: 1.19;
  letter-spacing: 0.012px;
}
.post-card h3 a { color: #1d1d1f; }
.post-card h3 a:hover { color: var(--link); text-decoration: none; }
.desc {
  color: rgba(0, 0, 0, 0.56);
  font-size: 0.875rem;
  line-height: 1.43;
  letter-spacing: -0.224px;
}
.tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.25rem; }
</style>
