---
// src/components/ProjectCard.astro
import TagChip from './TagChip.astro';
import { localizedPath, type Lang } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  tags: string[];
  repo?: string;
  demo?: string;
  slug: string;
  lang?: Lang;
}
const { title, description, tags, repo, demo, slug, lang = 'en' } = Astro.props;
---
<article class="card project-card" data-tags={tags.join(',')}>
  <h3><a href={localizedPath(`/projects/${slug}`, lang)}>{title}</a></h3>
  <p class="desc">{description}</p>
  <div class="tags">
    {tags.map(t => <TagChip tag={t} />)}
  </div>
  <div class="links">
    {repo && <a href={repo} target="_blank" rel="noopener">GitHub →</a>}
    {demo && <a href={demo} target="_blank" rel="noopener">Demo →</a>}
  </div>
</article>

<style>
.project-card h3 {
  margin-bottom: 0.5rem;
  font-family: var(--font-display);
  font-size: 1.19rem;
  font-weight: 600;
  line-height: 1.19;
  letter-spacing: 0.012px;
}
.project-card h3 a { color: #1d1d1f; }
.project-card h3 a:hover { color: var(--link); text-decoration: none; }
.desc {
  color: rgba(0, 0, 0, 0.56);
  font-size: 0.875rem;
  line-height: 1.43;
  letter-spacing: -0.224px;
  margin-bottom: 0.75rem;
}
.tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 0.75rem; }
.links { display: flex; gap: 1rem; font-size: 0.875rem; letter-spacing: -0.224px; }
.links a { color: var(--link); }
.links a:hover { color: var(--link); }
</style>
