---
// src/components/PublicationCard.astro
import TagChip from './TagChip.astro';

interface Props {
  title: string;
  authors: string[];
  venue: string;
  year: number;
  tags?: string[];
  pdf?: string;
  abstract?: string;
}
const { title, authors, venue, year, tags = [], pdf, abstract } = Astro.props;
---
<article class="card pub-card">
  <h3>
    {pdf
      ? <a href={pdf} target="_blank" rel="noopener">{title}</a>
      : title
    }
  </h3>
  <div class="authors">{authors.join(', ')}</div>
  <div class="venue">{venue}, {year}</div>
  {tags.length > 0 && (
    <div class="tags">
      {tags.map(t => <TagChip tag={t} />)}
    </div>
  )}

</article>

<style>
.pub-card h3 {
  margin-bottom: 0.5rem;
  font-family: var(--font-display);
  font-size: 1.19rem;
  font-weight: 600;
  line-height: 1.19;
  letter-spacing: 0.012px;
}
.pub-card h3 a { color: #1d1d1f; }
.pub-card h3 a:hover { color: var(--link); text-decoration: none; }
.authors {
  font-size: 0.875rem;
  color: rgba(0, 0, 0, 0.56);
  letter-spacing: -0.224px;
  margin-bottom: 0.25rem;
}
.venue {
  font-size: 0.875rem;
  color: var(--link);
  font-style: italic;
  letter-spacing: -0.224px;
  margin-bottom: 0.5rem;
}
.tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
</style>
