---
// src/components/NavLink.astro
import { localizedPath, type Lang } from '../i18n/ui';

interface Props {
  href: string;
  label: string;
  lang?: Lang;
}
const { href, label, lang = 'en' } = Astro.props;
const localHref = localizedPath(href, lang);
const pathname = Astro.url.pathname;
const isActive = pathname === localHref ||
  (localHref !== '/' && localHref !== '/zh' && pathname.startsWith(localHref + '/'));
---
<a href={localHref} class:list={['nav-link', { active: isActive }]}>
  {label}
</a>

<style>
.nav-link {
  display: block;
  padding: 0.4rem 0.75rem;
  color: var(--text-muted);
  font-size: 0.9rem;
  border-radius: var(--radius);
  border-left: 2px solid transparent;
  transition: color 0.15s, border-color 0.15s, background 0.15s;
}
.nav-link:hover {
  color: var(--text);
  background: rgba(255, 255, 255, 0.04);
}
.nav-link.active {
  color: var(--accent-1);
  border-left-color: var(--accent-1);
  background: rgba(16, 185, 129, 0.06);
}
</style>
