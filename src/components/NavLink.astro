---
// src/components/NavLink.astro
import { localizedPath, type Lang } from '../i18n/ui';

interface Props {
  href: string;
  label: string;
  lang?: Lang;
}
const { href, label, lang = 'en' } = Astro.props;
const localHref = localizedPath(href, lang);
const pathname = Astro.url.pathname;
const isActive = pathname === localHref ||
  (localHref !== '/' && localHref !== '/zh/' && pathname.startsWith(localHref));
---
<a href={localHref} class:list={['nav-link', { active: isActive }]}>
  {label}
</a>

<style>
.nav-link {
  display: block;
  padding: 0.4rem 0.75rem;
  color: rgba(0, 0, 0, 0.56);
  font-family: var(--font-text);
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: -0.224px;
  border-radius: 5px;
  transition: color 0.15s, background 0.15s;
}
.nav-link:hover {
  color: #1d1d1f;
  background: rgba(0, 0, 0, 0.04);
  text-decoration: none;
}
.nav-link.active {
  color: #1d1d1f;
  background: rgba(0, 0, 0, 0.06);
}
</style>
