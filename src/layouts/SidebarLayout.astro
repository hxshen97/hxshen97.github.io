---
// src/layouts/SidebarLayout.astro
import Sidebar from '../components/Sidebar.astro';
import '../styles/global.css';
import type { Lang } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
}
const { title, description = 'HxS — Software Engineer & Mathematician', lang = 'en' } = Astro.props;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | HxS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&family=Noto+Sans+SC:wght@400;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Sidebar lang={lang} />
    <main class="main-content">
      <slot />
    </main>
  </body>
</html>

<style>
.main-content {
  margin-left: var(--sidebar-w);
  min-height: 100vh;
  padding: 3rem;
  max-width: calc(var(--sidebar-w) + 860px);
}

@media (max-width: 768px) {
  .main-content {
    margin-left: 0;
    padding: 68px 1.25rem 2rem;
    max-width: 100%;
  }
}
</style>
